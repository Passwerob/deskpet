{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zhuochong",
  "version": "0.16.0",
  "identifier": "com.zhuochong.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "settings",
        "title": "桌宠",
        "width": 880,
        "height": 680,
        "minWidth": 760,
        "minHeight": 620,
        "center": true,
        "resizable": true
      },
      {
        "label": "pet-dog",
        "title": "dog · 豆包",
        "url": "index.html?window=pet&skin=dog",
        "width": 240,
        "height": 300,
        "transparent": true,
        "decorations": false,
        "shadow": false,
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": true,
        "skipTaskbar": true,
        "resizable": false,
        "visible": false
      },
      {
        "label": "pet-cream-dog",
        "title": "dog · 奶糖",
        "url": "index.html?window=pet&skin=cream-dog",
        "width": 240,
        "height": 300,
        "transparent": true,
        "decorations": false,
        "shadow": false,
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": true,
        "skipTaskbar": true,
        "resizable": false,
        "visible": false
      },
      {
        "label": "pet-corgi-tuantuan",
        "title": "dog · 团团",
        "url": "index.html?window=pet&skin=corgi-tuantuan",
        "width": 240,
        "height": 300,
        "transparent": true,
        "decorations": false,
        "shadow": false,
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": true,
        "skipTaskbar": true,
        "resizable": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "shortDescription": "一个带本地闹钟的丝滑桌宠",
    "longDescription": "独立运行的桌面宠物，支持动画互动、本地闹钟、托盘驻留和开机启动。"
  }
}
